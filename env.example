# ============================================================================
# AI Library Platform - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!

# ============================================================================
# Application Settings
# ============================================================================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL (Recommended for production)
DATABASE_URL=postgresql://username:password@localhost:5432/ai_library

# SQLite (Development only - current default)
# DATABASE_URL=file:./db/db.sqlite

# ============================================================================
# Redis Configuration
# ============================================================================
# Option 1: Redis Cloud / Standard Redis (Recommended)
REDIS_URL=redis://default:password@redis-host.com:port

# Option 2: Upstash Redis (Serverless alternative)
# UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-redis-rest-token

# ============================================================================
# AI API Keys
# ============================================================================
# Anthropic Claude API (Required)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# OpenAI GPT API (Optional - for multi-model support)
OPENAI_API_KEY=sk-your-openai-key-here

# Google Gemini API (Optional - coming soon)
# GOOGLE_AI_API_KEY=your-gemini-api-key-here

# ============================================================================
# Authentication & Security
# ============================================================================
# JWT Secret - Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Encryption keys for API keys and sensitive data
API_KEY_ENCRYPTION_KEY=your-encryption-key-change-in-production
ENCRYPTION_KEY=your-encryption-key-change-in-production

# Session secret for express-session
SESSION_SECRET=your-session-secret-change-in-production

# ============================================================================
# Payment Processing (Stripe)
# ============================================================================
# Get these from https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRO_PRICE_ID=price_your-pro-price-id
STRIPE_ENTERPRISE_PRICE_ID=price_your-enterprise-price-id

# ============================================================================
# External Integrations
# ============================================================================
# GitHub Integration (for repository cloning and deployment)
GITHUB_TOKEN=ghp_your-github-personal-access-token

# Vercel Integration (for deployments)
VERCEL_TOKEN=your-vercel-token

# ============================================================================
# Cloud Storage (Cloudflare R2)
# ============================================================================
# Get these from Cloudflare dashboard
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_ENDPOINT=https://your-account-id.eu.r2.cloudflarestorage.com

# ============================================================================
# Monitoring & Analytics
# ============================================================================
# Sentry Error Tracking (Optional but recommended)
# Backend DSN (from Node.js project)
SENTRY_DSN=https://your-key@sentry.io/your-backend-project-id
# Frontend DSN (from React project)
VITE_SENTRY_DSN=https://your-key@sentry.io/your-frontend-project-id
# Optional: App version for release tracking
VITE_APP_VERSION=1.0.0

# ============================================================================
# Cost Management
# ============================================================================
# Daily and monthly cost limits in USD
DAILY_COST_LIMIT=100
MONTHLY_COST_LIMIT=2000
USER_DAILY_COST_LIMIT=10
USER_MONTHLY_COST_LIMIT=100

# ============================================================================
# File Management
# ============================================================================
# Cleanup settings for temporary files
MAX_FILE_AGE_HOURS=24
CLEANUP_INTERVAL_HOURS=6

# ============================================================================
# OAuth Providers (Coming Soon)
# ============================================================================
# Google OAuth
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# ============================================================================
# Email Service (Coming Soon)
# ============================================================================
# SendGrid
# SENDGRID_API_KEY=your-sendgrid-api-key
# FROM_EMAIL=noreply@yourdomain.com

# ============================================================================
# WebContainer Configuration
# ============================================================================
# WebContainer API token (if required in future)
# WEBCONTAINER_API_KEY=your-webcontainer-api-key

# ============================================================================
# Development Tools
# ============================================================================
# Enable debug logging
DEBUG=false

# Enable SQL query logging
LOG_SQL_QUERIES=false

# ============================================================================
# Feature Flags
# ============================================================================
# Enable/disable features
ENABLE_OAUTH=false
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_WEBHOOKS=false
ENABLE_ANALYTICS=true
