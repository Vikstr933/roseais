# ==================================
# AI Code Generator Platform - Environment Configuration
# ==================================

# ----- DATABASE -----
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:your_password@db.your_supabase_project.supabase.co:5432/postgres

# Supabase specific (if using Supabase)
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ----- REDIS (Upstash) -----
# For caching and rate limiting
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your_redis_token

# ----- AI PROVIDERS -----
# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-api03-your_anthropic_key

# OpenAI API (optional, for additional AI features)
OPENAI_API_KEY=sk-your_openai_key

# ----- AUTHENTICATION -----
# Supabase Auth
AUTH_SECRET=your_random_secret_key_min_32_characters

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_CALLBACK_URL=http://localhost:5173/auth/callback

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5173/auth/callback

# Gmail integration OAuth redirect URI (points to backend)
GOOGLE_REDIRECT_URI=http://localhost:3001/api/plugins/gmail/callback

# Google Calendar integration OAuth redirect URI
GOOGLE_REDIRECT_URI_CALENDAR=http://localhost:3001/api/plugins/google-calendar/callback

# Notion integration (optional)
# Get your API key from: https://www.notion.so/my-integrations
NOTION_API_KEY=your_notion_api_key
# Optional: Parent page ID where new pages will be created
NOTION_PARENT_PAGE_ID=your_parent_page_id

# ----- STRIPE PAYMENTS -----
# Test mode keys (starts with sk_test_ and pk_test_)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs
# Create these in Stripe Dashboard → Products
STRIPE_PRO_PRICE_ID=price_your_pro_monthly_price_id
STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_monthly_price_id

# ----- ERROR TRACKING -----
# Sentry (for error monitoring)
SENTRY_DSN=https://your_sentry_key@sentry.io/your_project_id
SENTRY_ENV=development
SENTRY_ENABLED=false

# ----- APPLICATION -----
# Server configuration
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173

# ----- RATE LIMITING -----
# Requests per minute per IP
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ----- LOGGING -----
# Log level: debug, info, warn, error
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ----- FILE STORAGE -----
# Local storage path for generated files
WORKSPACE_PATH=./workspaces
TEMP_PATH=./temp

# AWS S3 (optional, for production file storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1

# ----- EMAIL (Optional) -----
# For sending transactional emails
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
EMAIL_FROM=noreply@yourdomain.com

# ----- ANALYTICS (Optional) -----
# Google Analytics
GA_TRACKING_ID=G-XXXXXXXXXX

# PostHog
POSTHOG_API_KEY=your_posthog_key
POSTHOG_HOST=https://app.posthog.com

# ----- FEATURE FLAGS -----
ENABLE_GITHUB_INTEGRATION=true
ENABLE_AI_TRAINING=true
ENABLE_TEAM_FEATURES=true
ENABLE_CUSTOM_DOMAINS=false

# ----- SECURITY -----
# Session secret (min 32 characters)
SESSION_SECRET=your_random_session_secret_min_32_characters_long

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ----- DEVELOPMENT -----
# Enable debug mode
DEBUG=false
VERBOSE_LOGGING=false

# Mock payments (for testing without Stripe)
MOCK_PAYMENTS=false

# ==================================
# QUICK START INSTRUCTIONS
# ==================================
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Fill in required values (marked with your_* placeholders)
#
# 3. Minimum required for development:
#    - DATABASE_URL
#    - ANTHROPIC_API_KEY
#    - AUTH_SECRET
#
# 4. For full features, configure:
#    - Stripe (for payments)
#    - Sentry (for error tracking)
#    - Redis (for caching)
#    - OAuth providers (for social login)
#
# 5. Start the development server:
#    npm run dev
#
# See STRIPE_SETUP_GUIDE.md for detailed Stripe setup
# ==================================
