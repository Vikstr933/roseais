# ==================================
# PRODUCTION ENVIRONMENT - Hybrid Deployment
# Frontend: Vercel | Backend: Render | Database: Supabase
# ==================================

# ----- DATABASE -----
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# Supabase
SUPABASE_URL=https://PROJECT.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ----- REDIS (Upstash) -----
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your_redis_token

# ----- AI PROVIDERS -----
ANTHROPIC_API_KEY=sk-ant-api03-your_anthropic_key
OPENAI_API_KEY=sk-your_openai_key

# ----- AUTHENTICATION -----
AUTH_SECRET=your_random_secret_key_min_32_characters

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_CALLBACK_URL=https://your-app.vercel.app/auth/callback

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-app.vercel.app/auth/callback

# Gmail integration (points to Render backend)
GOOGLE_REDIRECT_URI=https://your-backend.onrender.com/api/plugins/gmail/callback

# Google Calendar integration (points to Render backend)
GOOGLE_REDIRECT_URI_CALENDAR=https://your-backend.onrender.com/api/plugins/google-calendar/callback

# Notion integration
NOTION_API_KEY=your_notion_api_key
NOTION_PARENT_PAGE_ID=your_parent_page_id

# ----- STRIPE PAYMENTS -----
# Use live keys for production (starts with sk_live_ and pk_live_)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs
STRIPE_PRO_PRICE_ID=price_your_pro_monthly_price_id
STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_monthly_price_id

# ----- ERROR TRACKING -----
SENTRY_DSN=https://your_sentry_key@sentry.io/your_project_id
SENTRY_ENV=production
SENTRY_ENABLED=true

# ----- APPLICATION -----
PORT=10000
NODE_ENV=production

# IMPORTANT: Update these with your actual deployment URLs
FRONTEND_URL=https://your-app.vercel.app
BACKEND_URL=https://your-backend.onrender.com

# ----- CORS -----
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://your-app.vercel.app,https://www.your-domain.com

# ----- RATE LIMITING -----
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ----- LOGGING -----
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ----- FILE STORAGE -----
WORKSPACE_PATH=/opt/render/project/src/workspaces
TEMP_PATH=/tmp

# AWS S3 (recommended for production)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1

# ----- SECURITY -----
SESSION_SECRET=your_random_session_secret_min_32_characters_long

# ----- FEATURE FLAGS -----
ENABLE_GITHUB_INTEGRATION=true
ENABLE_AI_TRAINING=true
ENABLE_TEAM_FEATURES=true
ENABLE_CUSTOM_DOMAINS=false

# ==================================
# DEPLOYMENT CHECKLIST
# ==================================
#
# RENDER (Backend):
# 1. Create a new Web Service
# 2. Connect to your GitHub repo
# 3. Set build command: npm install && npm run build
# 4. Set start command: npm start
# 5. Add all environment variables from this file
# 6. Set health check path: /api/health
# 7. Deploy and note the URL (e.g., https://your-backend.onrender.com)
#
# VERCEL (Frontend):
# 1. Import your GitHub repo
# 2. Set build command: vite build
# 3. Set output directory: dist/public
# 4. Add environment variable:
#    VITE_API_URL=https://your-backend.onrender.com
# 5. Deploy and note the URL (e.g., https://your-app.vercel.app)
#
# AFTER DEPLOYMENT:
# 1. Update ALLOWED_ORIGINS in Render with Vercel URL
# 2. Update OAuth callback URLs with Vercel URL
# 3. Update Stripe webhook URL
# 4. Test the full application flow
# ==================================
